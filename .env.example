# Base de datos PostgreSQL
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# PIN de acceso al panel de administración (dejar vacío para deshabilitar)
PANEL_PIN=

# Token secreto para el endpoint /api/backup (Bearer token)
API_SECRET=

# Webhook n8n — URL completa del endpoint y token de autenticación
N8N_WEBHOOK_URL=http://IP:5678/webhook/api/v1/bunker-ganesha
N8N_TOKEN=

# Orígenes permitidos para CORS del webhook (separados por coma)
ALLOWED_ORIGINS=https://tu-dominio.vercel.app
